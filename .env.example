# AdImpactOs - Environment Configuration Example
# Copy this file to .env and update values as needed

# ============================================
# COSMOS DB CONFIGURATION
# ============================================

# Cosmos DB Emulator (Default for local development)
COSMOS_DB_ENDPOINT=https://localhost:8081
COSMOS_DB_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
COSMOS_DB_DATABASE=AdImpactOsDB

# Container names
COSMOS_DB_PANELIST_CONTAINER=Panelists
COSMOS_DB_BALANCE_CONTAINER=PointsBalance
COSMOS_DB_TRANSACTION_CONTAINER=Transactions

# ============================================
# AZURE EVENT HUB / KAFKA CONFIGURATION
# ============================================

# Local Kafka (Default for local development)
EVENT_HUB_CONNECTION=Endpoint=sb://eventhub:9092;EntityPath=ad-impressions
KAFKA_BOOTSTRAP_SERVERS=eventhub:9092

# Event Hub Topic/Entity
EVENT_HUB_TOPIC=ad-impressions
EVENT_HUB_CONSUMER_GROUP=$Default

# ============================================
# AZURE STORAGE / AZURITE CONFIGURATION
# ============================================

# Azurite (Default for local development)
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1;QueueEndpoint=http://azurite:10001/devstoreaccount1;TableEndpoint=http://azurite:10002/devstoreaccount1;

# Azure Functions Storage
AZURE_WEBJOBS_STORAGE=UseDevelopmentStorage=true

# ============================================
# APPLICATION SETTINGS
# ============================================

# ASP.NET Core Environment
ASPNETCORE_ENVIRONMENT=Development

# Logging Level (Trace, Debug, Information, Warning, Error, Critical)
LOGGING_LEVEL=Information

# ============================================
# API CONFIGURATION
# ============================================

# Panelist API
PANELIST_API_PORT=5001
PANELIST_API_URL=http://localhost:5001

# Incentives API
INCENTIVES_API_PORT=5002
INCENTIVES_API_URL=http://localhost:5002

# Azure Functions
FUNCTIONS_PORT=7071
FUNCTIONS_URL=http://localhost:7071

# ============================================
# AUTHENTICATION & SECURITY
# ============================================

# Azure AD B2C (Optional - for production)
# AZURE_AD_TENANT_ID=your-tenant-id
# AZURE_AD_CLIENT_ID=your-client-id
# AZURE_AD_CLIENT_SECRET=your-client-secret

# API Keys (Optional)
# API_KEY=your-api-key-here

# JWT Settings
# JWT_SECRET=your-jwt-secret-here
# JWT_ISSUER=https://your-domain.com
# JWT_AUDIENCE=https://your-domain.com

# ============================================
# KEY VAULT CONFIGURATION (Production)
# ============================================

# KEY_VAULT_URI=https://your-keyvault.vault.azure.net/
# KEY_VAULT_TENANT_ID=your-tenant-id
# KEY_VAULT_CLIENT_ID=your-client-id
# KEY_VAULT_CLIENT_SECRET=your-client-secret

# ============================================
# THIRD-PARTY SERVICES
# ============================================

# MaxMind GeoIP (Optional)
# MAXMIND_LICENSE_KEY=your-license-key
# MAXMIND_ACCOUNT_ID=your-account-id

# Payment Gateway (Optional)
# PAYMENT_GATEWAY_API_KEY=your-api-key
# PAYMENT_GATEWAY_SECRET=your-secret

# ============================================
# MONITORING & OBSERVABILITY
# ============================================

# Application Insights (Production)
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/

# Application Insights Instrumentation Key
# APPINSIGHTS_INSTRUMENTATIONKEY=your-instrumentation-key

# ============================================
# SPARK / DATABRICKS CONFIGURATION
# ============================================

# Spark Master
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2

# Databricks (Production)
# DATABRICKS_HOST=https://your-databricks-instance.azuredatabricks.net
# DATABRICKS_TOKEN=your-access-token

# ============================================
# BOT DETECTION CONFIGURATION
# ============================================

# Bot detection thresholds
BOT_DETECTION_ENABLED=true
BOT_DETECTION_THRESHOLD=0.7
BOT_DETECTION_RATE_LIMIT=100

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/disable features
ENABLE_SWAGGER=true
ENABLE_CORS=true
ENABLE_AUTHENTICATION=false
ENABLE_BOT_DETECTION=true
ENABLE_CACHING=false

# ============================================
# PERFORMANCE TUNING
# ============================================

# HTTP Request Timeout (seconds)
HTTP_TIMEOUT=30

# Max Request Body Size (bytes)
MAX_REQUEST_SIZE=10485760

# Connection Pool Settings
DB_MIN_POOL_SIZE=5
DB_MAX_POOL_SIZE=20

# Cache Settings (if Redis is used)
# CACHE_TTL=300
# REDIS_CONNECTION=localhost:6379

# ============================================
# DOCKER CONFIGURATION
# ============================================

# Container resource limits
CONTAINER_CPU_LIMIT=1.0
CONTAINER_MEMORY_LIMIT=512M

# Network configuration
DOCKER_NETWORK=adimpactos-network

# ============================================
# DEVELOPMENT SETTINGS
# ============================================

# Enable hot reload
DOTNET_WATCH_RESTART_ON_RUDE_EDIT=true

# Enable detailed errors
SHOW_DETAILED_ERRORS=true

# Seed sample data on startup
SEED_SAMPLE_DATA=false

# ============================================
# NOTES
# ============================================

# 1. This file should NOT be committed to version control
# 2. Add .env to .gitignore
# 3. For production, use Azure Key Vault or similar secret management
# 4. Update values in docker-compose.yml to use these environment variables
# 5. Use ${VARIABLE_NAME} syntax in docker-compose.yml to reference these values
