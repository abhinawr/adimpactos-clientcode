# Build stage
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Copy csproj and restore dependencies
COPY ["src/AdImpactOs/AdImpactOs.csproj", "AdImpactOs/"]
RUN dotnet restore "AdImpactOs/AdImpactOs.csproj"

# Copy everything else and build
COPY src/AdImpactOs/ AdImpactOs/
WORKDIR "/src/AdImpactOs"
RUN dotnet build "AdImpactOs.csproj" -c Release -o /app/build

# Publish stage
FROM build AS publish
RUN dotnet publish "AdImpactOs.csproj" -c Release -o /app/publish /p:UseAppHost=false

# Runtime stage
FROM mcr.microsoft.com/azure-functions/dotnet-isolated:4-dotnet-isolated10.0
ENV AzureWebJobsScriptRoot=/home/site/wwwroot \
    AzureFunctionsJobHost__Logging__Console__IsEnabled=true

COPY --from=publish /app/publish /home/site/wwwroot

EXPOSE 80
